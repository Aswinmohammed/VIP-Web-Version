VIP_ENVIRONMENT=staging
VIP_DATABASE_URL=postgresql+psycopg://vip_staging:${STAGING_DB_PASSWORD}@staging-db:5432/vip_tailors_staging
VIP_JWT_SECRET_KEY=${STAGING_JWT_SECRET}
VIP_ACCESS_TOKEN_EXPIRES_MINUTES=60
VIP_REFRESH_TOKEN_EXPIRES_DAYS=7
VIP_CREATE_TABLES_ON_STARTUP=false
VIP_CORS_ALLOW_ORIGINS=https://staging.your-domain.com
VIP_SMS_API_KEY=${STAGING_SMS_API_KEY}
VITE_API_PROXY_TARGET=https://staging.your-domain.com
