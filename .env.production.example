VIP_ENVIRONMENT=production
VIP_DATABASE_URL=postgresql+psycopg://vip_prod:${PROD_DB_PASSWORD}@prod-db:5432/vip_tailors_prod
VIP_JWT_SECRET_KEY=${PROD_JWT_SECRET}
VIP_ACCESS_TOKEN_EXPIRES_MINUTES=60
VIP_REFRESH_TOKEN_EXPIRES_DAYS=7
VIP_CREATE_TABLES_ON_STARTUP=false
VIP_CORS_ALLOW_ORIGINS=https://your-production-domain.com
VIP_SMS_API_KEY=${PROD_SMS_API_KEY}
VITE_API_PROXY_TARGET=https://your-production-domain.com
